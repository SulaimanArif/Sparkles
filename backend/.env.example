# Use the session pooler (port 5432) for reliable external connections.
# Username format: postgres.YOUR_PROJECT_REF
# URL-encode special characters in the password (e.g. ! → %21)

DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:5432/postgres?sslmode=require
